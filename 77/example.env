# VK Bot configuration
GROUP_TOKEN=your_vk_group_token_here
CONFIRM_TOKEN=your_vk_confirmation_token_here
GROUP_ID=your_vk_group_id_here
# Hub channel(s) for receiving messages (comma-separated for multiple)
CHANNEL=my_channel
# Hub URL for polling incoming messages
HUB_URL=https://api.php-cat.com/api/vk/incoming
# Long Poll proxy URL (instead of original VK API)
LONGPOLL_URL=https://api.php-cat.com/api/vk/longpoll

# Hub URL for polling incoming messages
HUB_URL=https://api.php-cat.com/api/vk/incoming

# Opencode API key is NOT required when using free models.
# If you want to use paid models, uncomment and set:
# OPENCODE_API_KEY=your_opencode_api_key_here

# Model for gateway.py (opencode run --model)
MODEL=opencode/deepseek-v4-flash-free